    "mcp",
    "model-context-protocol",
    "sf-symbols",
    "sfsymbols",
    "swift",
    "swiftui",
    "ai-agents"
  ],
  "homepage": "https://sfsymbolskit.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/WikipediaBrown/SFSymbolsKit",
    "directory": "mcp"
  },
  "license": "MIT",
